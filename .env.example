# Supabase Postgres connection strings.
# In your Supabase project: Project Settings -> Database -> Connection string.
#
# DATABASE_URL: the "Transaction" pooler connection (port 6543, pgbouncer) - used by the app at runtime.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: the "Session"/direct connection (port 5432, no pgbouncer) - used only for running migrations.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:5432/postgres"

# NextAuth (Auth.js) v5 - Google OAuth for /admin.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
# and https://<your-domain>/api/auth/callback/google (production).
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
